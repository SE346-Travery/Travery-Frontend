<!DOCTYPE html>

<html lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Success - Booking Confirmation</title>
<!-- Tailwind CSS CDN with plugins -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<!-- Google Fonts: Plus Jakarta Sans -->
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'azure-blue': '#0056b3',
            'azure-light-bg': '#f0f5f9',
            'azure-text-dark': '#1e3a5f',
          },
          fontFamily: {
            sans: ['"Plus Jakarta Sans"', 'sans-serif'],
          },
        },
      },
    }
  </script>
<style data-purpose="layout-adjustments">
    body {
      background-color: #f0f7ff; /* Matching the soft blue tint in background */
    }
    .main-container {
      max-width: 430px; /* Mobile standard width approximation */
      min-height: 100vh;
      margin: 0 auto;
    }
    /* Smooth shadow for the summary card */
    .card-shadow {
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    }
  </style>
</head>
<body class="font-sans antialiased text-azure-text-dark">
<!-- BEGIN: MainContainer -->
<main class="main-container flex flex-col h-screen px-6 pt-6 pb-12 relative overflow-hidden">
<!-- BEGIN: Header -->
<header class="flex items-center justify-between mb-12">
<!-- Close Button -->
<button class="text-azure-blue" data-purpose="close-button">
<svg class="h-6 w-6" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</button>
<!-- Screen Title -->
<h1 class="text-xl font-bold text-azure-blue">Success</h1>
<!-- Spacer for centering title -->
<div class="w-6"></div>
</header>
<!-- END: Header -->
<!-- BEGIN: SuccessMessageSection -->
<section class="flex flex-col items-center text-center mb-8" data-purpose="success-status">
<!-- Success Icon -->
<div class="w-24 h-24 bg-azure-blue rounded-full flex items-center justify-center mb-8">
<svg class="h-14 w-14 text-white" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="3"></path>
</svg>
</div>
<!-- Main Heading -->
<h2 class="text-[28px] leading-tight font-extrabold text-azure-blue px-4 mb-4">
        Đặt dịch vụ thành công!
      </h2>
<!-- Subtext -->
<p class="text-gray-500 text-[15px] leading-relaxed px-6">
        Yêu cầu của bạn đã được tiếp nhận và sẽ được phục vụ tại phòng.
      </p>
</section>
<!-- END: SuccessMessageSection -->
<!-- BEGIN: TransactionDetailsCard -->
<section class="bg-white rounded-2xl p-6 card-shadow mb-12" data-purpose="summary-card">
<!-- Transaction ID Row -->
<div class="flex justify-between items-center mb-4">
<span class="text-xs font-bold text-gray-500 uppercase tracking-wider">MÃ GIAO DỊCH</span>
<span class="text-sm font-medium text-gray-500">ID: #AS-8892</span>
</div>
<!-- Item Rows -->
<div class="space-y-4 mb-6">
<div class="flex justify-between items-center">
<span class="text-[15px] font-medium text-gray-800">Floating Breakfast</span>
<span class="text-[15px] font-medium text-gray-800">950.000đ</span>
</div>
<div class="flex justify-between items-center">
<span class="text-[15px] font-medium text-gray-800">Deep Tissue Massage</span>
<span class="text-[15px] font-medium text-gray-800">800.000đ</span>
</div>
</div>
<!-- Divider -->
<hr class="border-gray-100 mb-6"/>
<!-- Total Row -->
<div class="flex justify-between items-center">
<span class="text-xl font-bold text-gray-900">Tổng cộng</span>
<span class="text-xl font-bold text-azure-blue">1.750.000đ</span>
</div>
</section>
<!-- END: TransactionDetailsCard -->
<!-- BEGIN: ActionButtons -->
<section class="mt-auto flex flex-col gap-3" data-purpose="navigation-actions">
<!-- Primary Action -->
<button class="w-full bg-azure-blue text-white font-semibold py-4 rounded-xl shadow-lg shadow-blue-200 active:scale-[0.98] transition-transform">
        Quay lại trang chủ
      </button>
<!-- Secondary Action -->
<button class="w-full bg-transparent border border-azure-blue text-azure-blue font-semibold py-4 rounded-xl active:scale-[0.98] transition-transform">
        Xem đơn hàng của tôi
      </button>
</section>
<!-- END: ActionButtons -->
<!-- BEGIN: FooterLogo -->
<footer class="mt-8 flex justify-center opacity-20 grayscale pointer-events-none">
<!-- Subtle Watermark Logo Placeholder -->
<img alt="Azure Logo Watermark" class="h-10 object-contain" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCbrBVfcGuAP9HZhRJ61t88SF4Dm40pHMIpvgBWp0of-WhRc6unyvxoc1tV2qIpovdfVxz72ByKgLZZYdxF_qv0dc1kGQ93Qr-xkGa9UxD7V22gnWTCoVY7LWlqkoRF1j-x9gaCurTYygL5Zr0B7wdd9HyRdRVzYMfXR7EVPVIm_oIay-4Zygz6eRQMDbvYNkxMK3AIpfam7SGUzAqI8y5kTthQdYEyErAva6rP1pGTxEBphAwqJfZUj-vdWAKeNPvVKLrRApfBoQ"/>
</footer>
<!-- END: FooterLogo -->
</main>
<!-- END: MainContainer -->
</body></html>