<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: '#0056b3', /* Azure Serenity Blue - adjusted based on image visual */
            brandLight: '#007aff',
            surface: '#f8fbff',
            grayText: '#6b7280',
          },
          fontFamily: {
            sans: ['"Plus Jakarta Sans"', 'sans-serif'],
          },
          borderRadius: {
            'ROUND_EIGHT': '12px',
