<!DOCTYPE html>

<html lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Check-out Success</title>
<!-- BEGIN: Scripts -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'brand-blue': '#0059b3', /* Primary button and accent blue */
            'brand-bg': '#f5f9ff',   /* Light blue background */
            'success-blue': '#dbeafe', /* Light circle behind checkmark */
            'text-dark': '#1a1a1a',
            'text-gray': '#666666',
            'text-light-blue': '#007aff'
          }
        }
      }
    }
  </script>
<!-- END: Scripts -->
<style data-purpose="custom-typography">
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    body {
      font-family: 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
    }
    .check-icon-circle {
      background: #dbeafe;
      width: 80px;
      height: 80px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  </style>
</head>
<body class="bg-brand-bg min-h-screen flex flex-col items-center justify-center p-4">
<!-- BEGIN: MainContainer -->
<main class="w-full max-w-[375px] bg-white rounded-3xl shadow-sm overflow-hidden relative flex flex-col h-full min-h-[812px]">
<!-- BEGIN: HeaderNav -->
<header class="p-6 flex justify-start">
<button class="text-gray-500 hover:text-gray-700" data-purpose="close-button">
<svg class="h-6 w-6" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</button>
</header>
<!-- END: HeaderNav -->
<!-- BEGIN: SuccessMessage -->
<div class="flex flex-col items-center px-8 pt-4 pb-6 text-center">
<div class="check-icon-circle mb-6">
<div class="bg-brand-blue rounded-full p-2">
<svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" stroke-width="3" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
</div>
</div>
<h1 class="text-2xl font-bold text-text-dark mb-3">Check-out thành công!</h1>
<p class="text-sm text-gray-500 leading-relaxed">
        Cảm ơn bạn đã lựa chọn Azure Sands Resort &amp; Spa cho kỳ nghỉ vừa qua. Chúc bạn một hành trình tiếp theo bình an!
      </p>
</div>
<!-- END: SuccessMessage -->
<!-- BEGIN: DetailsSection -->
<div class="flex-grow px-4 pb-8">
<!-- Light gray container for all cards -->
<div class="bg-gray-50 rounded-2xl p-4 space-y-4">
<!-- BEGIN: LocationCard -->
<section class="bg-white rounded-xl p-4 shadow-sm border border-gray-100" data-purpose="resort-info-card">
<div class="flex justify-between items-start mb-1">
<span class="text-[10px] font-bold text-brand-blue tracking-wider uppercase">RESORT LOCATION</span>
<span class="text-[10px] font-medium text-gray-400">ID: #GH-98231</span>
</div>
<h2 class="text-xl font-bold text-text-dark mb-4">Azure Sands</h2>
<div class="grid grid-cols-2 gap-y-4 border-t border-gray-100 pt-4">
<div>
<p class="text-[10px] text-gray-400 font-medium">Guest Name</p>
<p class="text-xs font-bold text-text-dark leading-tight">Le Hoang<br/>Nam</p>
</div>
<div>
<p class="text-[10px] text-gray-400 font-medium">Room</p>
<p class="text-xs font-bold text-text-dark leading-tight">DELUXE, VIP</p>
</div>
<div class="col-span-2">
<p class="text-[10px] text-gray-400 font-medium">Stay Period</p>
<p class="text-xs font-bold text-text-dark">Oct 12 - Oct 15, 2023</p>
</div>
</div>
</section>
<!-- END: LocationCard -->
<!-- BEGIN: BillingCard -->
<section class="bg-white rounded-xl p-4 shadow-sm border border-gray-100" data-purpose="billing-info-card">
<div class="flex items-center gap-2 mb-4">
<svg class="h-5 w-5 text-brand-blue" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
<h3 class="text-lg font-bold text-text-dark">Detailed Bill</h3>
</div>
<div class="space-y-4">
<!-- Item 1 -->
<div class="flex items-start justify-between gap-2">
<div class="flex gap-2">
<svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="currentColor" viewbox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
<path clip-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" fill-rule="evenodd"></path>
</svg>
<p class="text-xs font-semibold text-text-dark leading-tight">In-Room Dining<br/>(Dinner)</p>
</div>
<span class="text-xs font-bold text-text-dark">1.250.000đ</span>
</div>
<!-- Item 2 -->
<div class="flex items-start justify-between gap-2 border-t border-gray-50 pt-3">
<div class="flex gap-2">
<svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="currentColor" viewbox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
<path clip-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" fill-rule="evenodd"></path>
</svg>
<p class="text-xs font-semibold text-text-dark leading-tight">Spa &amp; Wellness<br/>Treatment</p>
</div>
<span class="text-xs font-bold text-text-dark">3.800.000đ</span>
</div>
</div>
</section>
<!-- END: BillingCard -->
<p class="text-[11px] text-center text-gray-500 italic px-6 pt-2">
          “Chúc bạn có một chuyến đi tiếp theo thượng lộ bình an!”
        </p>
</div>
</div>
<!-- END: DetailsSection -->
<!-- BEGIN: FooterAction -->
<footer class="p-6 pt-0 mt-auto">
<button class="w-full bg-brand-blue text-white font-bold py-4 rounded-full shadow-lg hover:bg-blue-700 transition-colors" data-purpose="home-button">
        Quay về trang chủ
      </button>
</footer>
<!-- END: FooterAction -->
</main>
<!-- END: MainContainer -->
</body></html>