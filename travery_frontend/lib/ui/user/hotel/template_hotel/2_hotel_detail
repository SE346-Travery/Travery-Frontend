<span class="text-[10px] font-bold text-gray-700 uppercase">HỒ BƠI</span>
</div>
<!-- Amenity 2 -->
<div class="bg-gray-50 p-4 rounded-xl flex flex-col items-center justify-center text-center">
<i class="fa-solid fa-spa text-azure-blue text-xl mb-2"></i>
<span class="text-[10px] font-bold text-gray-700 uppercase">SPA &amp; WELLNESS</span>
</div>
<!-- Amenity 3 -->
<div class="bg-gray-50 p-4 rounded-xl flex flex-col items-center justify-center text-center">
<i class="fa-solid fa-utensils text-azure-blue text-xl mb-2"></i>
<span class="text-[10px] font-bold text-gray-700 uppercase">ẨM THỰ Á-ÂU</span>
</div>
<!-- Amenity 4 -->
<div class="bg-gray-50 p-4 rounded-xl flex flex-col items-center justify-center text-center">
<i class="fa-solid fa-wifi text-azure-blue text-xl mb-2"></i>
<span class="text-[10px] font-bold text-gray-700 uppercase">WIFI MIỄN PHÍ</span>
</div>
</section>
<!-- END: Amenities -->
<!-- BEGIN: RoomTypes -->
<section class="px-4 py-4" data-purpose="room-types-section">
<div class="flex justify-between items-center mb-4">
<h3 class="text-xl font-bold text-gray-800">Loại phòng</h3>
<a class="text-azure-blue text-xs font-medium" href="#">Xem thêm</a>
