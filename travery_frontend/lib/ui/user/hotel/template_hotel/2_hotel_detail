</div>
<div class="p-4">
<div class="flex justify-between items-start mb-3">
<h4 class="text-xl font-bold text-gray-800">Deluxe</h4>
<div class="text-right">
<span class="text-azure-blue font-bold">4.500.000đ</span>
<p class="text-[10px] text-gray-400">/ đêm</p>
</div>
</div>
<div class="flex flex-wrap gap-2">
<span class="bg-gray-100 text-gray-600 text-[10px] px-3 py-1 rounded">Hồ bơi riêng</span>
