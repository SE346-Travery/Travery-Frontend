        1 / 5
      </div>
</section>
<!-- END: HeroSection -->
<!-- BEGIN: HotelInfo -->
<section class="px-4 py-5 bg-white" data-purpose="hotel-details">
<div class="flex items-center mb-1">
<span class="text-yellow-400 text-xs mr-1"><i class="fa-solid fa-star"></i></span>
<span class="text-sm font-bold text-gray-400">4.9</span>
</div>
<h2 class="text-2xl font-bold text-gray-800 mb-1">Azure Sands Resort &amp; Spa</h2>
<div class="flex items-center text-gray-500 text-sm mb-4">
<i class="fa-solid fa-location-dot mr-1"></i>
<span>255 Trường Sa, Đà Nẵng</span>
</div>
<p class="text-gray-600 text-sm leading-relaxed">
        Trải nghiệm sự sang trọng bậc nhất tại bãi biển Đà Nẵng với dịch vụ đẳng cấp thế giới và tầm nhìn ngoạn mục ra đại dương xanh thẳm.
      </p>
</section>
<!-- END: HotelInfo -->
<!-- BEGIN: CheckInTime -->
<section class="mx-4 mt-4 p-4 bg-soft-blue rounded-xl flex justify-between items-center" data-purpose="checkin-info">
<span class="text-xs font-bold text-gray-400 uppercase">NHẬN/TRẢ PHÒNG</span>
<span class="font-bold text-gray-800">12:00 PM</span>
</section>
<!-- END: CheckInTime -->
<!-- BEGIN: Amenities -->
<section class="px-4 py-6 grid grid-cols-2 gap-3" data-purpose="amenities-grid">
