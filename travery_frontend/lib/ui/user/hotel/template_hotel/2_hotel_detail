<div class="absolute top-3 right-3 w-5 h-5 bg-white border-2 border-gray-200 rounded-full"></div>
</div>
<div class="p-4">
<div class="flex justify-between items-start mb-3">
<h4 class="text-xl font-bold text-gray-800">Deluxe</h4>
<div class="text-right">
<span class="text-azure-blue font-bold">4.500.000đ</span>
<p class="text-[10px] text-gray-400">/ đêm</p>
</div>
</div>
<div class="flex flex-wrap gap-2">
<span class="bg-gray-100 text-gray-600 text-[10px] px-3 py-1 rounded">Hồ bơi riêng</span>
<span class="bg-gray-100 text-gray-600 text-[10px] px-3 py-1 rounded">View biển</span>
<span class="bg-gray-100 text-gray-600 text-[10px] px-3 py-1 rounded">Quầy bar</span>
</div>
</div>
</div>
</section>
<!-- END: RoomTypes -->
<!-- BEGIN: Reviews -->
<section class="px-4 py-6" data-purpose="reviews-section">
<div class="flex justify-between items-center mb-6">
<div class="flex items-center gap-2">
<i class="fa-regular fa-star text-azure-blue"></i>
