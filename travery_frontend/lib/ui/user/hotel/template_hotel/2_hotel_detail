<div>
<p class="text-azure-blue text-xs font-bold">Đã chọn 1 phòng</p>
<p class="text-sm font-bold text-gray-700">Tổng cộng: 450.000đ</p>
</div>
<button class="bg-azure-blue text-white px-10 py-3 rounded-xl font-bold text-sm">
      Đặt ngay
    </button>
</footer>
<!-- END: BottomBar -->
</body></html>