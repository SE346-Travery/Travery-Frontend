<!DOCTYPE html>

<html lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Thông tin đặt phòng</title>
<!-- Tailwind CSS v3 CDN -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<!-- Custom Tailwind Configuration -->
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'travery-blue': '#007bff',
            'bg-light-blue': '#f4f7fe',
            'card-bg': '#ffffff',
            'input-bg': '#edf0ff',
            'text-primary': '#1e293b',
            'text-secondary': '#64748b',
          },
          fontFamily: {
            sans: ['Inter', 'Segoe UI', 'Roboto', 'sans-serif'],
          },
        }
      }
    }
  </script>
<!-- Custom Styles for UI Fidelity -->
<style data-purpose="custom-ui-refinements">
    body {
      background-color: #f0f4ff; /* Light blueish backdrop */
    }
    .main-container {
      max-width: 430px; /* Mobile width */
      min-height: 100vh;
      margin: 0 auto;
      background: white;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    /* Style for the calendar icon inside input */
    .calendar-icon-input {
      background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="%2364748b" class="bi bi-calendar" viewBox="0 0 16 16"><path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/></svg>');
      background-repeat: no-repeat;
      background-position: right 10px center;
    }
    .guest-card-border-1 {
      border-left: 4px solid #3b82f6;
    }
    .guest-card-border-2 {
      border-left: 4px solid #cbd5e1;
    }
  </style>
</head>
<body class="text-slate-800 antialiased">
<!-- BEGIN: MainContainer -->
<div class="main-container flex flex-col p-4 bg-[#f8faff]">
<!-- BEGIN: Header -->
<header class="flex items-center gap-4 py-4 mb-2" data-purpose="page-header">
<button aria-label="Go back" class="p-1">
<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
</button>
<h1 class="text-lg font-bold text-slate-800">Thông tin đặt phòng</h1>
</header>
<!-- END: Header -->
<main class="flex-grow space-y-6">
<!-- BEGIN: RoomInfoSection -->
<section data-purpose="room-info">
<h2 class="text-xl font-bold mb-3 text-slate-800">Thông tin phòng</h2>
<div class="bg-white rounded-2xl p-5 shadow-sm space-y-3">
<div class="flex justify-between text-sm">
<span class="text-slate-500">Loại phòng:</span>
<span class="font-semibold text-slate-700">VIP, DELUXE</span>
</div>
<div class="flex justify-between text-sm">
<span class="text-slate-500">Số lượng:</span>
<span class="font-semibold text-slate-700">2</span>
</div>
<div class="flex justify-between text-sm">
<span class="text-slate-500">Giá tiền:</span>
<span class="font-bold text-blue-600">4.450.000đ</span>
</div>
</div>
</section>
<!-- END: RoomInfoSection -->
<!-- BEGIN: GuestListSection -->
<section data-purpose="guest-list-container">
<div class="flex justify-between items-center mb-4">
<h2 class="text-xl font-bold text-slate-800">Danh sách khách</h2>
<button class="flex items-center gap-1 text-blue-500 text-sm font-semibold">
<svg class="w-5 h-5" fill="currentColor" viewbox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
<path clip-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v2.5h-2.5a.75.75 0 000 1.5h2.5v2.5a.75.75 0 001.5 0v-2.5h2.5a.75.75 0 000-1.5h-2.5v-2.5z" fill-rule="evenodd"></path>
</svg>
            Thêm khách
          </button>
</div>
<div class="space-y-4">
<!-- Guest 1 Card -->
<div class="bg-white rounded-xl p-4 shadow-sm guest-card-border-1 relative" data-purpose="guest-card">
<div class="mb-4">
<span class="bg-blue-100 text-blue-600 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider">Khách 1</span>
</div>
<div class="space-y-4">
<div>
<label class="block text-xs font-medium text-slate-500 mb-1">Họ và tên</label>
<input class="w-full bg-indigo-50/50 border-none rounded-xl py-3 px-4 text-slate-400 text-sm focus:ring-1 focus:ring-blue-400" type="text" value="VD: NGUYEN VAN A"/>
</div>
<div class="grid grid-cols-2 gap-3">
<div>
<label class="block text-xs font-medium text-slate-500 mb-1">Số hộ chiếu/CCCD</label>
<input class="w-full bg-indigo-50/50 border-none rounded-xl py-3 px-4 text-slate-400 text-sm focus:ring-1 focus:ring-blue-400" type="text" value="012345678"/>
</div>
<div>
<label class="block text-xs font-medium text-slate-500 mb-1">Ngày sinh</label>
<input class="w-full bg-indigo-50/50 border-none rounded-xl py-3 px-4 text-slate-400 text-sm calendar-icon-input focus:ring-1 focus:ring-blue-400" type="text" value="DD/MM/YYYY"/>
</div>
</div>
</div>
</div>
<!-- Guest 2 Card -->
<div class="bg-white rounded-xl p-4 shadow-sm guest-card-border-2 relative" data-purpose="guest-card">
<div class="flex justify-between items-center mb-4">
<span class="bg-slate-200 text-slate-500 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider">Khách 2</span>
<button class="text-red-500">
<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
</button>
</div>
<div class="space-y-4">
<div>
<label class="block text-xs font-medium text-slate-500 mb-1">Họ và tên</label>
<input class="w-full bg-indigo-50/50 border-none rounded-xl py-3 px-4 text-slate-400 text-sm focus:ring-1 focus:ring-blue-400" type="text" value="VD: TRAN THI B"/>
</div>
<div class="grid grid-cols-2 gap-3">
<div>
<label class="block text-xs font-medium text-slate-500 mb-1">Số hộ chiếu/CCCD</label>
<input class="w-full bg-indigo-50/50 border-none rounded-xl py-3 px-4 text-slate-400 text-sm focus:ring-1 focus:ring-blue-400" type="text" value="987654321"/>
</div>
<div>
<label class="block text-xs font-medium text-slate-500 mb-1">Ngày sinh</label>
<input class="w-full bg-indigo-50/50 border-none rounded-xl py-3 px-4 text-slate-400 text-sm calendar-icon-input focus:ring-1 focus:ring-blue-400" type="text" value="DD/MM/YYYY"/>
</div>
</div>
</div>
</div>
</div>
</section>
<!-- END: GuestListSection -->
<!-- BEGIN: PolicySection -->
<section class="mt-8 flex items-start gap-3" data-purpose="terms-agreement">
<input class="mt-1 h-5 w-5 rounded border-slate-300 text-blue-600 focus:ring-blue-500" type="checkbox"/>
<p class="text-xs text-slate-500 leading-relaxed">
          Tôi đồng ý với <a class="text-blue-500 underline" href="#">Điều khoản &amp; Chính sách</a> của Travery và khách sạn.
        </p>
</section>
<!-- END: PolicySection -->
</main>
<!-- BEGIN: FooterAction -->
<footer class="mt-12 mb-4 space-y-4" data-purpose="footer-action">
<div class="flex justify-between items-center">
<span class="text-slate-500 text-sm">Tổng cộng</span>
<span class="text-xl font-bold text-blue-600">4.250.000 đ</span>
</div>
<button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-2xl shadow-lg transition-colors" data-purpose="payment-button">
        Tiếp tục thanh toán
      </button>
</footer>
<!-- END: FooterAction -->
</div>
<!-- END: MainContainer -->
</body></html>