<!DOCTYPE html>

<html lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Chi tiết đặt phòng</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<style data-purpose="typography">
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background-color: #f8faff;
    }
  </style>
<style data-purpose="custom-shadows">
    .card-shadow {
      box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.03);
    }
  </style>
</head>
<body class="flex flex-col min-h-screen text-[#1a1a1a]">
<!-- BEGIN: MainHeader -->
<header class="bg-white px-4 py-4 sticky top-0 z-10 border-b border-gray-50" data-purpose="header-section">
<div class="flex items-center gap-4">
<!-- Back Arrow Icon -->
<button aria-label="Quay lại" class="p-1">
<svg fill="none" height="24" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg">
<path d="M10 19l-7-7m0 0l7-7m-7 7h18" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
</button>
<h1 class="text-lg font-bold">Chi tiết đặt phòng</h1>
</div>
</header>
<!-- END: MainHeader -->
<main class="flex-grow p-4 space-y-6 pb-32" data-purpose="main-content">
<!-- BEGIN: StatusAndBookingID -->
<section class="space-y-4">
<div class="flex justify-end">
<span class="bg-[#e0edff] text-[#007aff] px-3 py-1 rounded-full text-xs font-semibold">
          Đã thanh toán
        </span>
</div>
<div class="bg-white rounded-2xl p-5 flex items-center gap-4 card-shadow border border-gray-50" data-purpose="booking-id-card">
<div class="w-12 h-12 bg-[#e0edff] rounded-xl flex items-center justify-center">
<!-- Bed Icon -->
<svg fill="none" height="24" viewbox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg">
<path d="M3 10V18C3 19.1046 3.89543 20 5 20H19C20.1046 20 21 19.1046 21 18V10M3 10V6C3 4.89543 3.89543 4 5 4H19C20.1046 4 21 4.89543 21 6V10M3 10H21M7 14H17" stroke="#007aff" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<div class="text-lg font-semibold">
          Mã đặt phòng: <span class="text-gray-900">###4410</span>
</div>
</div>
</section>
<!-- END: StatusAndBookingID -->
<!-- BEGIN: CustomerInfo -->
<section data-purpose="customer-info-section">
<h2 class="text-base font-bold mb-3">Thông tin khách hàng</h2>
<div class="bg-white rounded-2xl p-5 space-y-5 card-shadow border border-gray-50">
<!-- Customer Name -->
<div class="flex items-center gap-4">
<div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center">
<svg fill="none" height="20" stroke="#6b7280" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewbox="0 0 24 24" width="20">
<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
<circle cx="12" cy="7" r="4"></circle>
</svg>
</div>
<div>
<p class="text-xs text-gray-500 font-medium">Tên khách hàng</p>
<p class="text-[15px] font-bold">Nguyễn Văn A</p>
</div>
</div>
<!-- ID Number -->
<div class="flex items-center gap-4">
<div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center">
<svg fill="none" height="20" stroke="#6b7280" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewbox="0 0 24 24" width="20">
<rect height="16" rx="2" width="18" x="3" y="4"></rect>
<path d="M7 8h10M7 12h10M7 16h10"></path>
</svg>
</div>
<div>
<p class="text-xs text-gray-500 font-medium">Số CCCD</p>
<p class="text-[15px] font-bold">012345678910</p>
</div>
</div>
</div>
</section>
<!-- END: CustomerInfo -->
<!-- BEGIN: AddedServices -->
<section data-purpose="added-services-section">
<h2 class="text-base font-bold mb-3">Dịch vụ đã thêm</h2>
<div class="bg-white rounded-2xl p-5 space-y-6 card-shadow border border-gray-50">
<!-- Service 1 -->
<div class="flex items-start justify-between gap-3">
<div class="flex items-start gap-3">
<div class="mt-1">
<svg fill="none" height="20" viewbox="0 0 24 24" width="20">
<circle cx="12" cy="12" fill="#22c55e" r="10"></circle>
<path d="M8 12L11 15L16 9" stroke="white" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<div>
<p class="text-[15px] font-bold leading-tight">In-Room Dining<br/>(Dinner)</p>
</div>
</div>
<p class="text-[15px] font-bold">1.250.000đ</p>
</div>
<!-- Service 2 -->
<div class="flex items-start justify-between gap-3">
<div class="flex items-start gap-3">
<div class="mt-1">
<svg fill="none" height="20" viewbox="0 0 24 24" width="20">
<circle cx="12" cy="12" fill="#22c55e" r="10"></circle>
<path d="M8 12L11 15L16 9" stroke="white" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<div>
<p class="text-[15px] font-bold leading-tight">Spa &amp; Wellness<br/>Treatment</p>
</div>
</div>
<p class="text-[15px] font-bold">3.800.000đ</p>
</div>
</div>
</section>
<!-- END: AddedServices -->
<!-- BEGIN: PaymentDetails -->
<section data-purpose="payment-details-section">
<h2 class="text-base font-bold mb-3">Chi tiết thanh toán</h2>
<div class="bg-white rounded-2xl p-5 space-y-3 card-shadow border border-gray-50">
<div class="flex justify-between items-center">
<span class="text-sm text-gray-500 font-medium">Giá phòng (3 đêm)</span>
<span class="text-sm font-semibold">12.450.000đ</span>
</div>
<div class="flex justify-between items-center">
<span class="text-sm text-gray-500 font-medium">Dịch vụ</span>
<span class="text-sm font-semibold">5.000.000đ</span>
</div>
<div class="pt-3 border-t border-gray-100 flex justify-between items-center">
<span class="text-base font-bold">Tổng cộng</span>
<span class="text-xl font-extrabold text-[#007aff]">17.195.000đ</span>
</div>
</div>
</section>
<!-- END: PaymentDetails -->
<!-- BEGIN: UpsellAction -->
<section class="flex flex-col items-center py-6" data-purpose="upsell-section">
<p class="text-xs text-gray-500 font-medium mb-4">Bạn cần thêm dịch vụ gì cho phòng này ?</p>
<button class="px-10 py-2.5 rounded-full border border-[#007aff] text-[#007aff] text-sm font-bold bg-[#f4f8ff]">
        Thêm dịch vụ
      </button>
</section>
<!-- END: UpsellAction -->
</main>
<!-- BEGIN: BottomActions -->
<footer class="fixed bottom-0 left-0 right-0 bg-white p-4 border-t border-gray-100 flex gap-4" data-purpose="footer-actions">
<button class="flex-1 py-3.5 rounded-xl border border-red-500 text-red-600 font-bold text-[15px]" data-purpose="cancel-btn">
      Hủy đặt phòng
    </button>
<button class="flex-1 py-3.5 rounded-xl bg-[#007aff] text-white font-bold text-[15px]" data-purpose="checkout-btn">
      Checkout
    </button>
</footer>
<!-- END: BottomActions -->
</body></html>