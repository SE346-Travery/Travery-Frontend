<!DOCTYPE html><html lang="vi" style=""><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Bus Ticket Search Results</title>
<!-- Tailwind CSS v3 CDN -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#007AFF',
            primaryDark: '#0056B3',
          }
        }
      }
    }
  </script>
<style data-purpose="layout-styles">
    /* Hide scrollbar for the date strip but allow scrolling */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"></head>
<body class="bg-gray-50 text-gray-800 font-sans">
<!-- BEGIN: MainHeader -->
<header class="bg-primary text-white pt-6 pb-4 px-4 sticky top-0 z-50 shadow-md" data-purpose="app-header">
<div class="flex items-center gap-4">
<!-- Back Arrow -->
<button aria-label="Go back" class="p-1">
<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M15 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</button>
<div class="flex-1 text-center">
<h1 class="text-lg font-bold">TP. Hồ Chí Minh → Đồng Nai</h1>
<p class="text-xs opacity-90">Wednesday, 27/05/2026</p>
</div>
<!-- Placeholder for symmetry -->
<div class="w-8"></div>
</div>
</header>
<!-- END: MainHeader -->
<!-- BEGIN: DateStrip -->
<section class="bg-white border-b border-gray-200" data-purpose="date-selector">
<div class="flex overflow-x-auto no-scrollbar py-3 px-2 gap-2">
<!-- Active Date -->
<div class="flex flex-col items-center justify-center min-w-[70px] h-16 bg-primary text-white rounded-xl shadow-sm" data-purpose="active-date">
<span class="text-xs">Wed</span>
<span class="text-lg font-bold">27/05</span>
</div>
<!-- Other Dates -->
<div class="flex flex-col items-center justify-center min-w-[70px] h-16 text-gray-500">
<span class="text-xs">Thu</span>
<span class="text-lg font-semibold">28/05</span>
</div>
<div class="flex flex-col items-center justify-center min-w-[70px] h-16 text-gray-500">
<span class="text-xs">Fri</span>
<span class="text-lg font-semibold">29/05</span>
</div>
<div class="flex flex-col items-center justify-center min-w-[70px] h-16 text-gray-500">
<span class="text-xs">Sat</span>
<span class="text-lg font-semibold">30/05</span>
</div>
<div class="flex flex-col items-center justify-center min-w-[70px] h-16 text-gray-500">
<span class="text-xs">Sun</span>
<span class="text-lg font-semibold">31/05</span>
</div>
</div>
</section>
<!-- END: DateStrip -->
<!-- BEGIN: FilterSection -->
<section class="p-4 flex gap-3 overflow-x-auto no-scrollbar" data-purpose="filter-controls">
<button class="flex items-center gap-1 px-4 py-2 bg-gray-100 rounded-full text-sm font-medium border border-gray-200">
      Price
      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
<path clip-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" fill-rule="evenodd"></path>
</svg>
</button>
<button class="flex items-center gap-1 px-4 py-2 bg-gray-100 rounded-full text-sm font-medium border border-gray-200">
      Chair
      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
<path clip-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" fill-rule="evenodd"></path>
</svg>
</button>
<button class="flex items-center gap-1 px-4 py-2 bg-gray-100 rounded-full text-sm font-medium border border-gray-200">
      Hour
      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
<path clip-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" fill-rule="evenodd"></path>
</svg>
</button>
</section>
<!-- END: FilterSection -->
<!-- BEGIN: TripList -->
<main class="px-4 pb-10 space-y-4" data-purpose="trip-results-list">
<!-- Card 1 -->
<article class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 overflow-hidden" data-purpose="trip-card">
<div class="flex justify-between items-center mb-4">
<div class="flex items-center gap-3">
<span class="text-2xl font-bold">09:00</span>
<span class="text-gray-400">
<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</span>
<span class="text-2xl font-bold">15:25</span>
</div>
<!-- Note: Icons removed as per instructions -->
</div>
<!-- Info Badge Row -->
<div class="flex items-center bg-gray-50 rounded-full px-4 py-2 mb-6 text-sm text-gray-600">
<span class="text-primary font-bold">220,000đ</span>
<span class="mx-2 text-gray-300">•</span>
<span class="flex-1 text-center font-medium">Ghế - Limousine</span>
<span class="mx-2 text-gray-300">•</span>
<span class="">15 seats left</span>
</div>
<!-- Route Tracking -->
<div class="relative pl-6 space-y-6">
<!-- Vertical Line -->
<div class="absolute left-1.5 top-2 bottom-2 w-0.5 border-l-2 border-dotted border-gray-300"></div>
<!-- Start Point -->
<div class="relative">
<div class="absolute -left-6 top-1 w-4 h-4 bg-white border-2 border-[#4CAF50] rounded-full flex items-center justify-center"><div class="w-1.5 h-1.5 bg-[#4CAF50] rounded-full"></div></div>
<div>
<h3 class="font-semibold text-gray-900">Miền Tây</h3>
<p class="text-xs text-gray-500 mt-1">Distance: 222km - 6 h 25m</p>
</div>
</div>
<!-- End Point -->
<div class="relative">
<div class="absolute -left-[27px] top-0.5">
<span class="material-symbols-outlined text-[#F44336] text-[20px]" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;">location_on</span>
</div>
<div>
<h3 class="font-semibold text-gray-900">Mũi Né</h3>
</div>
</div>
</div>
<!-- Note: Trip schedule link and yellow warning removed as per instructions -->
</article>
<!-- Card 2 -->
<article class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 overflow-hidden" data-purpose="trip-card">
<div class="flex justify-between items-center mb-4">
<div class="flex items-center gap-3">
<span class="text-2xl font-bold">09:00</span>
<span class="text-gray-400">
<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</span>
<span class="text-2xl font-bold">13:06</span>
</div>
<!-- Service Icons (Simplified representation) -->
<div class="flex gap-2 text-gray-400">
<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a8 8 0 100 16 8 8 0 000-16zM5.94 5.5c.618 0 1.12.502 1.12 1.12s-.502 1.12-1.12 1.12-1.12-.502-1.12-1.12.502-1.12 1.12-1.12z"></path></svg>
<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5z"></path></svg>
<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path clip-rule="evenodd" d="M17.707 9.293a1 1 0 010 1.414l-7 7a1 1 0 01-1.414 0l-7-7A.997.997 0 012 10V5a3 3 0 013-3h5c.265 0 .52.105.707.293l7 7zM5 6a1 1 0 100-2 1 1 0 000 2z" fill-rule="evenodd"></path></svg>
</div>
</div>
<!-- Info Badge Row -->
<div class="flex items-center bg-gray-50 rounded-full px-4 py-2 mb-6 text-sm text-gray-600">
<span class="text-primary font-bold">160,000đ</span>
<span class="mx-2 text-gray-300">•</span>
<span class="flex-1 text-center font-medium">Ghế</span>
<span class="mx-2 text-gray-300">•</span>
<span class="">12 seats left</span>
</div>
<!-- Route Tracking -->
<div class="relative pl-6 space-y-6 mb-4">
<!-- Vertical Line -->
<div class="absolute left-1.5 top-2 bottom-2 w-0.5 border-l-2 border-dotted border-gray-300"></div>
<!-- Start Point -->
<div class="relative">
<div class="absolute -left-6 top-1 w-4 h-4 bg-white border-2 border-[#4CAF50] rounded-full flex items-center justify-center"><div class="w-1.5 h-1.5 bg-[#4CAF50] rounded-full"></div></div>
<div>
<h3 class="font-semibold text-gray-900">Miền Tây</h3>
<p class="text-xs text-gray-500 mt-1">Distance: 133km - 4 h 6m</p>
</div>
</div>
<!-- End Point -->
<div class="relative">
<div class="absolute -left-[27px] top-0.5">
<span class="material-symbols-outlined text-[#F44336] text-[20px]" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;">location_on</span>
</div>
<div>
<h3 class="font-semibold text-gray-900">Vũng Tàu</h3>
</div>
</div>
</div>
<!-- Action Link: Kept for Card 2 as per instruction -->
</article>
</main>
<!-- END: TripList -->


</body></html>