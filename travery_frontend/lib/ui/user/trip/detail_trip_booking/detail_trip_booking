<!DOCTYPE html><html lang="vi"><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Chi tiết đặt vé</title>
<!-- Tailwind CSS CDN -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<!-- Font link for a clean sans-serif look -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
<style data-purpose="global-styles">
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f0f5ff; /* Light blueish gray background from image */
    }
  </style>
<style data-purpose="custom-decorations">
    .status-badge {
      background-color: #e6f7ed;
      color: #2e7d32;
    }
    .ticket-card {
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    }
    /* Simple separator styling */
    .section-divider {
      border-top: 1px dashed #e5e7eb;
    }
  </style>
</head>
<body class="flex justify-center min-h-screen">
<!-- Mobile Container Wrapper -->
<main class="w-full max-w-[390px] min-h-screen bg-[#f8faff] flex flex-col relative" data-purpose="mobile-viewport">
<!-- BEGIN: Header -->
<header class="bg-white px-4 py-4 flex items-center border-b border-gray-100 sticky top-0 z-10" data-purpose="main-header">
<button aria-label="Go back" class="p-1 -ml-1">
<svg class="h-6 w-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M10 19l-7-7m0 0l7-7m-7 7h18" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</button>
<h1 class="ml-4 text-lg font-bold text-gray-800">Chi tiết đặt vé</h1>
</header>
<!-- END: Header -->
<!-- Scrollable Content Area -->
<div class="flex-1 p-4 space-y-4 overflow-y-auto">
<!-- BEGIN: Ticket Status Card -->
<section class="bg-white rounded-2xl p-4 flex items-center justify-between ticket-card" data-purpose="status-section">
<div class="flex items-center gap-3">
<!-- Green checkmark icon circle -->
<div class="bg-green-600 rounded-full p-1">
<svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="3"></path>
</svg>
</div>
<span class="text-gray-700 font-semibold text-sm">Trạng thái vé</span>
</div>
<span class="status-badge px-3 py-1 rounded-full text-xs font-bold">Đã thanh toán</span>
</section>
<!-- END: Ticket Status Card -->
<!-- BEGIN: Main Booking Card -->
<article class="bg-white rounded-2xl p-5 ticket-card space-y-6" data-purpose="booking-details">
<!-- Trip Info Section -->
<section class="space-y-3" data-purpose="trip-info">
<div class="flex justify-between items-start">
<div class="space-y-1">
<span class="text-[10px] font-bold text-gray-400 tracking-wider uppercase">CHUYẾN ĐI</span>
<h2 class="text-lg font-bold text-gray-800">TP HCM → Đà Lạt</h2>
</div>
<span class="text-blue-700 font-bold text-lg">59A-123.45</span>
</div>
<div class="flex justify-between items-center">
<div class="flex items-center gap-2 text-gray-500 text-sm">
<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
<span>19/05/2026</span>
</div>
<span class="text-blue-500 font-bold text-lg">280.000đ</span>
</div>
</section>
<!-- Passenger Info Section -->
<section class="space-y-4 pt-2" data-purpose="passenger-info">
<h3 class="text-[10px] font-bold text-gray-400 tracking-wider uppercase">THÔNG TIN HÀNH KHÁCH</h3>
<!-- Row: Full Name -->
<div class="flex items-center justify-between">
<div class="flex items-center gap-3 text-gray-500">
<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
<span class="text-sm">Họ tên</span>
</div>
<span class="text-sm font-medium text-gray-700">Nguyen Van A</span>
</div>
<!-- Row: Phone Number -->
<div class="flex items-center justify-between">
<div class="flex items-center gap-3 text-gray-500">
<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
<span class="text-sm">Số điện thoại</span>
</div>
<span class="text-sm font-bold text-gray-800">096475361</span>
</div>
</section>
<!-- Totals Section -->
<section class="bg-blue-50 rounded-xl p-4 flex justify-between items-center" data-purpose="total-price-display">
<span class="text-gray-600 font-medium">Tổng cộng</span>
<span class="text-blue-600 font-bold text-xl">280.000đ</span>
</section>
<!-- BEGIN: Cancel Button -->
<div class="pt-10 pb-2">
<button class="w-full py-4 border border-red-200 rounded-xl text-red-500 font-bold flex items-center justify-center gap-2 hover:bg-red-50 active:scale-[0.98] transition-all" data-purpose="cancel-booking-button">
<!-- Red X Icon inside a circle -->
<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
            Hủy vé
          </button>
</div>
<!-- END: Cancel Button -->
</article>
<!-- END: Main Booking Card -->
</div>
</main>
</body></html>