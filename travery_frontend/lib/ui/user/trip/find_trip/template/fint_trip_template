<script>
        // Micro-interaction for toggle
        const toggle = document.getElementById('roundtrip-toggle');
        const returnDateBox = document.getElementById('return-date-box');
        
        toggle.addEventListener('change', () => {
            if (toggle.checked) {
                returnDateBox.classList.remove('opacity-50');
                returnDateBox.classList.add('opacity-100', 'border-primary');
            } else {
                returnDateBox.classList.add('opacity-50');
                returnDateBox.classList.remove('opacity-100', 'border-primary');
            }
        });

        // Swap button animation
        const swapBtn = document.getElementById('swap-btn');
        swapBtn.addEventListener('click', () => {
            swapBtn.querySelector('span').classList.add('rotate-180');
            setTimeout(() => {
                swapBtn.querySelector('span').classList.remove('rotate-180');
            }, 300);
        });
    </script>






