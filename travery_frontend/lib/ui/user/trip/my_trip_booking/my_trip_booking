<!DOCTYPE html><html lang="vi"><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Đơn đặt vé của tôi</title>
<!-- BEGIN: Tailwind CSS Setup -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'transit-blue': '#003366',
            'transit-light-blue': '#F0F7FF',
            'status-paid': '#10B981',
            'status-pending': '#F59E0B',
            'status-completed': '#EF4444',
          }
        }
      }
    }
  </script>
<!-- END: Tailwind CSS Setup -->
<style data-purpose="custom-shadows">
    .card-shadow {
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    }
  </style>
</head>
<body class="bg-transit-light-blue font-sans text-gray-800">
<!-- Main Container: Mobile view simulator -->
<div class="max-w-[390px] mx-auto min-h-screen flex flex-col bg-white relative">
<!-- BEGIN: Header -->
<header class="pt-10 pb-6 px-6 flex items-center bg-white" data-purpose="screen-header">
<button aria-label="Go back" class="mr-4">
