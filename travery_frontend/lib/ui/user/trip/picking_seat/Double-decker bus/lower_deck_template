</button>
</div>
</header>
<main class="flex-grow pb-32">
<!-- Floor Tabs -->
<div class="bg-surface px-margin-mobile py-4 sticky top-16 z-40 border-b border-outline-variant">
<div class="flex bg-surface-container rounded-lg p-1">
<button class="flex-1 py-2 text-center rounded-md font-label-lg transition-all bg-primary text-on-primary shadow-sm" id="btn-first-floor" onclick="switchFloor('first')">
                    Tầng dưới
                </button>
<button class="flex-1 py-2 text-center rounded-md font-label-lg transition-all text-on-surface-variant hover:text-on-surface" id="btn-top-floor" onclick="switchFloor('top')">
                    Tầng trên
                </button>
</div>
</div>
<!-- Spacer for removed Departure Date section -->
<div class="py-4"></div>
<!-- Seat Map Container -->
<div class="max-w-md mx-auto px-margin-mobile">
<div class="bg-surface-container-lowest rounded-xl p-6 border border-outline-variant shadow-sm relative overflow-hidden" id="seat-layout">
<!-- Bus Front Indicator -->
<div class="w-full flex flex-col items-center mb-8 border-b border-dashed border-outline-variant pb-4">
<span class="material-symbols-outlined text-outline-variant text-4xl mb-1">directions_bus</span>
<span class="font-label-md text-label-md text-outline">Đầu xe</span>
</div>
<!-- First Floor Grid -->
<div class="seat-grid" id="first-floor-grid">
<!-- Left Side -->
