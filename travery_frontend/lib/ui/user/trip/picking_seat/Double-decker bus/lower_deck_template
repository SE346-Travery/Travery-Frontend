<div class="seat-grid hidden" id="top-floor-grid">
<div class="flex flex-col gap-4">
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">B04</div>
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">B08</div>
</div>
<div class="flex flex-col gap-4">
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">B03</div>
