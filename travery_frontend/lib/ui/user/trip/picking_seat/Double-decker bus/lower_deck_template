<div class="flex flex-col">
<span class="font-label-md text-label-md text-on-surface-variant">Tổng cộng</span>
<span class="font-title-lg text-title-lg text-primary" id="price-display">160.000đ</span>
</div>
<button class="flex-1 bg-primary text-on-primary font-title-md py-4 rounded-xl shadow-lg hover:bg-primary-container transition-all active:scale-95">
                Tiếp tục
            </button>
</div>
</footer>
<script>
        function switchFloor(floor) {
            const firstGrid = document.getElementById('first-floor-grid');
            const topGrid = document.getElementById('top-floor-grid');
            const firstBtn = document.getElementById('btn-first-floor');
            const topBtn = document.getElementById('btn-top-floor');

            if (floor === 'first') {
                firstGrid.classList.remove('hidden');
                topGrid.classList.add('hidden');
                firstBtn.classList.add('bg-primary', 'text-on-primary', 'shadow-sm');
                firstBtn.classList.remove('text-on-surface-variant');
                topBtn.classList.remove('bg-primary', 'text-on-primary', 'shadow-sm');
                topBtn.classList.add('text-on-surface-variant');
            } else {
                firstGrid.classList.add('hidden');
                topGrid.classList.remove('hidden');
                topBtn.classList.add('bg-primary', 'text-on-primary', 'shadow-sm');
                topBtn.classList.remove('text-on-surface-variant');
                firstBtn.classList.remove('bg-primary', 'text-on-primary', 'shadow-sm');
                firstBtn.classList.add('text-on-surface-variant');
            }
        }

        function toggleSeat(element) {
            const status = element.getAttribute('data-status');
            
            if (status === 'available') {
                element.setAttribute('data-status', 'selected');
                element.classList.remove('bg-surface', 'text-on-surface-variant', 'border-outline-variant');
                element.classList.add('bg-primary-container/20', 'border-primary', 'text-primary');
            } else if (status === 'selected') {
                element.setAttribute('data-status', 'available');
                element.classList.add('bg-surface', 'text-on-surface-variant', 'border-outline-variant');
                element.classList.remove('bg-primary-container/20', 'border-primary', 'text-primary');
            }
            
            updatePrice();
        }

        function updatePrice() {
            const selectedCount = document.querySelectorAll('[data-status="selected"]').length;
            const unitPrice = 160000;
            const totalPrice = selectedCount * unitPrice;
            
            // Format number to Vietnamese locale with dots
            const formattedPrice = totalPrice.toLocaleString('vi-VN');
            document.getElementById('price-display').innerText = `${formattedPrice}đ`;
        }
        
        // Initialize price on load
        updatePrice();
    </script>
