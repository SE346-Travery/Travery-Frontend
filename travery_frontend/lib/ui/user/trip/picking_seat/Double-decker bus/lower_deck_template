<div class="seat flex items-center justify-center w-full aspect-square rounded-lg bg-surface-container-highest text-outline border-2 border-transparent font-title-md cursor-not-allowed opacity-60" data-status="sold">A08</div>
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">A12</div>
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">A16</div>
</div>
<div class="flex flex-col gap-4">
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">A03</div>
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">A07</div>
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">A11</div>
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">A15</div>
</div>
<!-- Aisle -->
<div class="flex flex-col items-center justify-start pt-2">
<div class="w-1 h-full bg-surface-container rounded-full opacity-50"></div>
</div>
<!-- Right Side -->
<div class="flex flex-col gap-4">
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">A02</div>
