</div>
<div class="flex flex-col gap-4">
<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">B02</div>
<div class="seat flex items-center justify-center w-full aspect-square rounded-lg bg-surface-container-highest text-outline border-2 border-transparent font-title-md cursor-not-allowed opacity-60" data-status="sold">B06</div>
</div>
<div class="flex flex-col gap-4">
