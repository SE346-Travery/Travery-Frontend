<div class="seat cursor-pointer flex items-center justify-center w-full aspect-square rounded-lg border-2 border-outline-variant bg-surface text-on-surface-variant font-title-md hover:border-primary transition-all" data-status="available" onclick="toggleSeat(this)">B05</div>
