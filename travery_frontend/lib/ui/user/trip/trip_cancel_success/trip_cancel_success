<!DOCTYPE html><html lang="vi" style=""><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Thông báo hủy xe thành công</title>
<!-- Tailwind CSS v3 CDN -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<!-- Google Fonts: Inter -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'primary': '#007aff',
            'surface': '#f9f9fe',
            'surface-container-lowest': '#ffffff',
            'surface-container-low': '#f3f3f8',
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          },
          borderRadius: {
            'custom': '8px',
          }
        }
      }
    }
  </script>
<style data-purpose="custom-typography">
    body {
      font-family: 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
    }
  </style>
</head>
<body class="bg-[#e8f0fe] min-h-screen flex items-center justify-center p-4">
<!-- BEGIN: Mobile Container -->
<main class="w-full max-w-[375px] bg-surface min-h-[812px] shadow-2xl relative flex flex-col overflow-hidden" data-purpose="main-screen">
<!-- BEGIN: Header -->
<header class="flex items-center px-4 py-6 bg-white" data-purpose="top-navigation">
<button aria-label="Go back" class="p-2 -ml-2 text-primary">
<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
</button>
<h1 class="ml-2 text-lg font-bold text-primary">Thông báo</h1>
</header>
<!-- END: Header -->
<!-- BEGIN: Success Status -->
<section class="flex flex-col items-center pt-10 px-6" data-purpose="success-status">
<!-- Success Icon -->
<div class="w-20 h-20 bg-[#e6f0ff] rounded-full flex items-center justify-center mb-6">
<div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center">
<svg class="w-6 h-6" fill="none" stroke="white" stroke-width="4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
</div>
</div>
<h2 class="text-xl font-bold text-[#1a1a1a] mb-3">Hủy xe thành công!</h2>
<p class="text-center text-[#666666] text-sm leading-relaxed px-4">
        Yêu cầu hủy xe của bạn đã được xác nhận.
      </p>
</section>
<!-- END: Success Status -->
<!-- BEGIN: Refund Details Card -->
<section class="mt-8 px-4" data-purpose="details-container">
<div class="bg-white rounded-2xl p-5 shadow-sm space-y-5">
<!-- Header Title with Icon -->
<div class="flex items-center space-x-2 pb-2 border-b border-gray-50">
<div class="text-primary">
<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
</div>
<h3 class="font-bold text-[#1a1a1a]">Thông tin hoàn tiền</h3>
</div>
<!-- Info Rows -->
<div class="space-y-4">
<!-- Row: Booking ID -->
<div class="flex justify-between items-center">
<span class="text-sm text-[#666666]">Mã giao dịch</span>
<span class="text-sm font-semibold text-[#1a1a1a]">TRV-8829-VN</span>
</div>
<!-- Row: Amount -->
<div class="flex justify-between items-center">
<span class="text-sm text-[#666666]">Số tiền hoàn lại</span>
<span class="text-sm font-bold text-primary">12.500.000đ</span>
</div>
<!-- Row: Payment Method -->

<!-- Row: Processing Time -->
<div class="flex justify-between items-start">
<span class="text-sm text-[#666666]">Thời gian xử lý dự kiến</span>
<span class="text-sm font-semibold text-[#1a1a1a] text-right max-w-[120px]">3-5 ngày làm việc</span>
</div>
</div>
</div>
</section>
<!-- END: Refund Details Card -->
<!-- BEGIN: Note Section -->
<section class="mt-6 px-4" data-purpose="notification-note">
<div class="bg-[#eff6ff] rounded-xl p-4 flex items-start space-x-3 border-l-4 border-primary">
<div class="text-primary mt-0.5 shrink-0">
<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
</div>
<p class="text-xs text-[#334155] leading-relaxed">
<span class="font-bold">Lưu ý:</span> Tiền sẽ được hoàn về đúng phương thức thanh toán bạn đã sử dụng.
        </p>
</div>
</section>
<!-- END: Note Section -->
<!-- BEGIN: Bottom Action -->
<footer class="mt-auto pb-10 px-4" data-purpose="footer-actions">
<button class="w-full bg-primary hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-200 transition-colors active:scale-[0.98]">
        Về trang chủ
      </button>
</footer>
<!-- END: Bottom Action -->
</main>
<!-- END: Mobile Container -->
</body></html>