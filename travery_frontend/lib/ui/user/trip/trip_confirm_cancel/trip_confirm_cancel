<!DOCTYPE html><html lang="vi"><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Xác nhận hủy vé</title>
<!-- Tailwind CSS CDN with plugins -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<!-- Google Fonts: Inter -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: '#007aff',
            surface: '#f9f9fe',
            'surface-dim': '#d9dade',
            'surface-container': '#ffffff',
            'warning-bg': '#fee2e2',
            'warning-icon': '#dc2626',
            'info-bg': '#f3f4f6'
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          },
          borderRadius: {
            'custom': '8px',
          }
        }
      }
    }
  </script>
<style data-purpose="custom-layouts">
    body {
      background-color: #f1f5f9; /* Outer background to simulate mobile container */
      font-family: 'Inter', sans-serif;
    }
    .mobile-container {
      max-width: 390px;
      min-height: 844px;
      margin: 0 auto;
      background-color: #f9f9fe;
      position: relative;
      display: flex;
      flex-direction: column;
    }
    /* Dashed border for ticket info separator */
    .border-dashed-custom {
      border-top: 1px dashed #d1d5db;
    }
  </style>
</head>
<body class="antialiased text-slate-900">
<div class="mobile-container shadow-xl overflow-hidden">
<!-- BEGIN: TopAppBar -->
<header class="bg-white border-b border-gray-100 px-4 py-4 flex items-center">
<button aria-label="Go back" class="p-1">
<svg class="h-6 w-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M10 19l-7-7m0 0l7-7m-7 7h18" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</button>
<h1 class="flex-1 text-center text-lg font-semibold text-slate-800 pr-8">Xác nhận hủy vé</h1>
</header>
<!-- END: TopAppBar -->
<!-- BEGIN: MainContent -->
<main class="flex-1 overflow-y-auto px-6 pt-10 pb-4">
<!-- Warning Icon Section -->
<div class="flex justify-center mb-8" data-purpose="status-icon">
<div class="w-24 h-24 bg-red-100 rounded-full flex items-center justify-center">
<svg class="h-12 w-12 text-warning-icon" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 2L1 21h22L12 2zm1 16h-2v-2h2v2zm0-4h-2V8h2v6z"></path>
</svg>
</div>
</div>
<!-- Confirmation Text -->
<div class="text-center mb-10">
<h2 class="text-xl font-bold text-slate-800 leading-tight mb-3">Bạn có chắc chắn muốn hủy vé này?</h2>
<p class="text-slate-500 text-sm leading-relaxed px-4">
          Hành động này không thể hoàn tác sau khi đã xác nhận.
        </p>
</div>
<!-- BEGIN: TicketDetailsCard -->
<div class="bg-white rounded-xl shadow-sm border border-gray-50 p-5 mb-6" data-purpose="ticket-info-card">
<div class="mb-4">
<p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">MÃ GIAO DỊCH</p>
<p class="text-lg font-bold text-slate-800">TVY-99218A</p>
</div><div class="mb-4">
<p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">CHUYẾN ĐI</p>
<p class="text-lg font-bold text-slate-800">TP HCM -&gt; Vũng Tàu</p>
</div>
<div class="border-dashed-custom my-4"></div>
<div class="flex justify-between items-center mb-4">
<span class="text-sm text-slate-500">Giá vé</span>
<span class="text-sm font-semibold text-slate-800">280.000đ</span>
</div><div class="mb-4">
<p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">CHUYẾN ĐI</p>
<p class="text-lg font-bold text-slate-800">TP HCM -&gt; Vũng Tàu</p>
</div>
<div class="flex justify-between items-center text-brand">
<span class="text-sm font-medium">Số tiền hoàn lại:</span>
<span class="text-lg font-bold">28.000đ</span>
</div>
</div>
<!-- END: TicketDetailsCard -->
<!-- BEGIN: InfoNotice -->
<div class="bg-[#f2f4f7] rounded-xl p-4 flex gap-3" data-purpose="info-box">
<div class="flex-shrink-0 mt-0.5">
<svg class="h-5 w-5 text-brand" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
<path clip-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" fill-rule="evenodd"></path>
</svg>
</div>
<p class="text-[13px] leading-snug text-slate-600 font-medium">
<span class="font-bold text-slate-800">Lưu ý quan trọng:</span> Tiền sẽ được hoàn về phương thức thanh toán ban đầu trong vòng 3-5 ngày làm việc tùy thuộc vào ngân hàng của bạn.
        </p>
</div>
<!-- END: InfoNotice -->
</main>
<!-- END: MainContent -->
<!-- BEGIN: BottomActionButtons -->
<footer class="p-6 space-y-3 bg-white border-t border-gray-50">
<button class="w-full bg-brand hover:bg-blue-600 text-white font-bold py-4 rounded-xl flex items-center justify-center gap-2 transition-colors active:scale-[0.98]" data-purpose="confirm-button">
<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
<path clip-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" fill-rule="evenodd"></path>
</svg>
        Xác nhận hủy
      </button>
<button class="w-full bg-[#e9e9ee] hover:bg-gray-200 text-slate-700 font-bold py-4 rounded-xl transition-colors active:scale-[0.98]" data-purpose="back-button">
        Quay lại
      </button>
</footer>
<!-- END: BottomActionButtons -->
</div>


</body></html>